# Google Sheets 設定
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials.json
SPREADSHEET_ID=your_spreadsheet_id_here

# ── 縦向きレイアウト（日付・売上が列に並ぶ場合）──
# DATE_COLUMN=0   # A列=0, B列=1, C列=2 ...
# SALES_COLUMN=1
# HEADER_ROW=1    # 1行目がヘッダーなら1、ヘッダーなしなら0

# ── 横向きレイアウト（日付・売上が行に並ぶ場合）──
DATE_ROW=2        # 日付が入っている行番号（スプレッドシートの行番号そのまま）
SALES_ROW=29      # 売上が入っている行番号
START_COLUMN=1    # データが始まる列番号（A列=0, B列=1 ...）

# 店舗の場所（天候データ取得用）
LATITUDE=35.6762
LONGITUDE=139.6503
LOCATION_NAME=東京

# 予測設定
FORECAST_YEAR=2026
